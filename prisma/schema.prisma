generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("partner")
  accounts      Account[]
  sessions      Session[]
  deals         Deal[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Deal {
  id           String @id @default(cuid())
  name         String
  address      String
  city         String
  state        String
  zipCode      String
  propertyType String @default("Single Family")
  status       String @default("Prospecting")

  // Purchase
  purchasePrice  Float
  downPaymentPct Float @default(20)
  closingCosts   Float @default(0)
  rehabCosts     Float @default(0)

  // Income
  monthlyRent Float

  // Expenses (propertyTax is annual; all others are monthly)
  propertyTax Float @default(0)
  insurance   Float @default(0)
  maintenance Float @default(0)
  utilities   Float @default(0)
  hoaFees     Float @default(0)

  // Loan terms
  interestRate  Float @default(7)
  loanTermYears Int   @default(30)

  // Rates
  vacancyRate   Float @default(5)
  managementFee Float @default(0)

  notes     String?
  zillowUrl String?

  addedBy   User     @relation(fields: [addedById], references: [id])
  addedById String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
